# Kiro Gateway — Docker Deployment Environment Template
# Copy this file to .env and fill in the required values.
#
# NOTE: The following settings are managed by docker-compose.yml and must NOT
# be set here (docker-compose environment: block takes precedence, but having
# them here causes confusion):
#   SERVER_HOST, TLS_ENABLED, KIRO_CLI_DB_FILE, CONFIG_DB, TLS_CERT, TLS_KEY

# ==================================================================================================
# Required
# ==================================================================================================

# Password that clients must supply in the Authorization: Bearer header.
# Use a strong, unique value — this is the only thing protecting your proxy.
PROXY_API_KEY=change-me-to-a-strong-password

# AWS region where your Kiro / CodeWhisperer endpoint lives.
KIRO_REGION=us-east-1

# ==================================================================================================
# Optional overrides (uncomment to change from defaults)
# ==================================================================================================

# HTTP port the gateway listens on (default: 8000).
# Must match the port exposed in docker-compose.yml.
# SERVER_PORT=8000

# Log verbosity: trace | debug | info | warn | error (default: info)
# LOG_LEVEL=info

# Request debug logging: off | errors | all (default: off)
# DEBUG_MODE=off

# Enable the web UI dashboard at /_ui/ (default: true)
# WEB_UI=true

# Outbound HTTP timeouts in seconds (defaults: 300)
# HTTP_REQUEST_TIMEOUT=300
# STREAMING_READ_TIMEOUT=300

# Retry attempts for failed upstream requests (default: 3)
# HTTP_MAX_RETRIES=3

# Token refresh threshold in seconds before expiry (default: 300)
# TOKEN_REFRESH_THRESHOLD=300

# First-token timeout: cancel and retry if no token received within N seconds (default: 15)
# FIRST_TOKEN_TIMEOUT=15
