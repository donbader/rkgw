# Proxy-only mode environment variables
# Copy to .env.proxy and set PROXY_API_KEY
#
# Usage: docker compose -f docker-compose.gateway.yml --env-file .env.proxy up -d

# Required: Deployment mode
GATEWAY_MODE=proxy

# Required: API key for client authentication
PROXY_API_KEY=your-api-key-here

# ── Kiro (default provider, uses device code flow if no token set) ───
# KIRO_ENABLED=true
# KIRO_REGION=us-east-1
# KIRO_SSO_REGION=
# KIRO_SSO_URL=

# ── Anthropic (OAuth relay, connect after startup) ─────────────────
# ANTHROPIC_ENABLED=false
# ANTHROPIC_OAUTH_CLIENT_ID=

# ── OpenAI (OAuth relay, connect after startup) ────────────────────
# OPENAI_ENABLED=false
# OPENAI_OAUTH_CLIENT_ID=

# ── GitHub Copilot (device flow runs if token not set) ───────────────
# COPILOT_ENABLED=false
# COPILOT_TOKEN=
# COPILOT_BASE_URL=https://api.githubcopilot.com

# ── General ──────────────────────────────────────────────────────────
# BIND_ADDRESS=127.0.0.1
# SERVER_PORT=8000
# LOG_LEVEL=info
# DEBUG_MODE=off
